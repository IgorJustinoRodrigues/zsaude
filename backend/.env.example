# ─── Ambiente ─────────────────────────────────────────────────────────────────
ENV=dev                                # dev | staging | prod
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
DEBUG=true

# ─── API ──────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=zsaude
POSTGRES_PASSWORD=zsaude_dev_password
POSTGRES_DB=zsaude
DATABASE_URL=postgresql+asyncpg://zsaude:zsaude_dev_password@postgres:5432/zsaude

# ─── Valkey ──────────────────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gerar com: uv run python -m scripts.generate_jwt_keys
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_RESET_TTL_MINUTES=15
WORK_CONTEXT_TTL_MINUTES=480

# ─── Segurança ───────────────────────────────────────────────────────────────
# Pepper HMAC-SHA256 aplicado antes do Argon2id. NUNCA mudar sem rotacionar.
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
PASSWORD_PEPPER=change-me-to-a-long-random-secret-pepper-value-with-high-entropy

# Chave Fernet pra cifrar secrets em repouso (API keys de IA, senha CadSUS).
# Gerar: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Obrigatória ao rodar a migration 0018 e nas Fases do gateway de IA.
SECRETS_ENCRYPTION_KEY=

# ─── E-mail ──────────────────────────────────────────────────────────────────
# smtp → usa SMTP (MailHog em dev, server externo em staging/prod)
# ses  → usa AWS SES (aioboto3)
# null → descarta (útil em testes)
EMAIL_BACKEND=smtp
EMAIL_FROM=nao-responder@zsaude.local
EMAIL_FROM_NAME=zSaúde
# URL pública do frontend. Usada para montar links em e-mails (reset, verify).
APP_PUBLIC_URL=http://localhost:5179

# SMTP (dev → MailHog; prod → servidor real)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM=nao-responder@zsaude.local

# AWS SES (só em prod; as creds NUNCA podem ir pro git)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=
