# ─── Ambiente ─────────────────────────────────────────────────────────────────
ENV=dev                                # dev | staging | prod
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
DEBUG=true

# ─── API ──────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5179

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=zsaude
POSTGRES_PASSWORD=zsaude_dev_password
POSTGRES_DB=zsaude
DATABASE_URL=postgresql+asyncpg://zsaude:zsaude_dev_password@postgres:5432/zsaude

# ─── Valkey ──────────────────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ─── Object Storage (S3/MinIO) ──────────────────────────────────────────────
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=zsaude-files
STORAGE_REGION=us-east-1

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gerar com: uv run python -m scripts.generate_jwt_keys
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_RESET_TTL_MINUTES=15
WORK_CONTEXT_TTL_MINUTES=480

# ─── Segurança ───────────────────────────────────────────────────────────────
# Pepper HMAC-SHA256 aplicado antes do Argon2id. NUNCA mudar sem rotacionar.
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
PASSWORD_PEPPER=-L3BvHXt3JyQF4EXSq3oA3IU_WGRavylurTJMg4CG2eVxKdWuy7KwDSSctSeVpfp

# Chave Fernet (32 bytes base64-url) pra cifrar secrets em repouso.
# Gerar: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
SECRETS_ENCRYPTION_KEY=0pXvs8_23npKVsxL86d7RnCz4UVjMQkBEAxKbbCFcS4=

# ─── SMTP (MailHog em dev) ───────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=nao-responder@zsaude.local

# ─── CadSUS (integração DATASUS) ─────────────────────────────────────────────
# Em dev sem credenciais, ligar mock retorna paciente fake pra testar UI.
CADSUS_MOCK=true
CADSUS_URL=https://servicos.saude.gov.br/cadsus/PDQSupplier
CADSUS_USER=
CADSUS_PASSWORD=
CADSUS_TIMEOUT_SECONDS=15
